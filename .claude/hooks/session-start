#!/usr/bin/env bash
# session-start: inject pointer to canonical project rules into Claude Code session.
# Keep this hook minimal — canonical content lives in CLAUDE.md and .claude/rules/.
# Exit 0 = success, non-zero = failure (session continues regardless).

context="Gitizens — git-native civilization simulator.

Canonical references (read on demand):
  - CLAUDE.md                    core constraints (world/ write rules, branch protection)
  - .claude/rules/testing.md     three-step verification per change
  - .claude/rules/python.md      source-code language and emoji rules
  - .claude/skills/git/SKILL.md  commit message format and types

Slash commands:
  /git — compose a conventional commit message from the staged diff"

# Escape for JSON: backslashes, quotes, newlines, tabs.
escaped="${context//\\/\\\\}"
escaped="${escaped//\"/\\\"}"
escaped="${escaped//$'\n'/\\n}"
escaped="${escaped//$'\r'/\\r}"
escaped="${escaped//$'\t'/\\t}"

printf '{"hookSpecificOutput":{"additionalContext":"%s"}}' "$escaped"
exit 0
